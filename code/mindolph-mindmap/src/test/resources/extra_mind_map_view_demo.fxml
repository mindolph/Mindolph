<?xml version="1.0" encoding="UTF-8"?>

<?import com.mindolph.base.container.ScalableScrollPane?>
<?import com.mindolph.mindmap.view.AttributesView?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindolph.mindmap.ExtraMindMapViewDemo">
    <VBox layoutX="50.0" layoutY="31.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0"
          AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
        <ToolBar prefHeight="40.0" prefWidth="200.0">
            <Button mnemonicParsing="false" onAction="#onBig" text="Big"/>
            <Button mnemonicParsing="false" onAction="#onSmall" text="Small"/>
        </ToolBar>
        <ToolBar prefWidth="200">
            <Button mnemonicParsing="false" onAction="#onUndo" text="Undo"/>
            <Button mnemonicParsing="false" onAction="#onRedo" text="Redo"/>
        </ToolBar>
        <ScalableScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS">
        </ScalableScrollPane>
        <AttributesView fx:id="attributesView" maxHeight="200"/>
    </VBox>
</AnchorPane>
