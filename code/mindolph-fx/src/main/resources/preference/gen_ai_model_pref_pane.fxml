<?xml version="1.0" encoding="UTF-8"?>

<?import com.mindolph.base.container.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<fx:root prefHeight="450.0" prefWidth="1000.0" type="AnchorPane" xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1">

    <VBox>
        <PreferenceItem name="%prefs.ai.provider" labelMinWidth="180" labelPrefWidth="180">
            <ChoiceBox fx:id="cbProvider" prefWidth="140.0">
            </ChoiceBox>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.provider.api.key" labelMinWidth="180" labelPrefWidth="180">
            <TextField fx:id="tfApiKey" prefWidth="300.0"/>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.provider.base.url" labelMinWidth="180" labelPrefWidth="180">
            <TextField fx:id="tfBaseUrl" prefWidth="300.0" promptText="eg: http://127.0.0.1:11434"/>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.provider.use.proxy" labelMinWidth="180" labelPrefWidth="180">
            <tooltip>
                <Tooltip text="%prefs.ai.provider.use.proxy.tooltip"/>
            </tooltip>
            <CheckBox fx:id="cbUseProxy"/>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.provider.models" labelMinWidth="180" labelPrefWidth="180">
            <VBox spacing="8">
                <HBox spacing="8">
                    <ListView fx:id="lvModels" prefHeight="300"/>
                    <Button fx:id="btnAdd"/>
                    <Button fx:id="btnRemove" disable="true"/>
                </HBox>
                <HBox spacing="8">
                    <Label fx:id="lbMaxOutputTokens" text="%prefs.ai.provider.model.max.tokens"/>
                </HBox>
            </VBox>
        </PreferenceItem>

    </VBox>


</fx:root>
