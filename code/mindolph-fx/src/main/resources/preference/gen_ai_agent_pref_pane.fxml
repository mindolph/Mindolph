<?xml version="1.0" encoding="UTF-8"?>

<?import com.mindolph.base.container.PreferenceItem?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import com.mindolph.fx.control.DatasetTableView?>
<?import com.mindolph.mfx.control.MChoiceBox?>
<fx:root prefHeight="450.0" prefWidth="1000.0" type="AnchorPane" xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1">
    <VBox>
        <PreferenceItem name="%prefs.ai.agent" labelMinWidth="180" labelPrefWidth="180">
            <ChoiceBox fx:id="cbAgent" prefWidth="240.0">
            </ChoiceBox>
            <Button fx:id="btnAddAgent"/>
            <Button fx:id="btnRemoveAgent"/>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.agent.name" labelMinWidth="180" labelPrefWidth="180">
            <TextField fx:id="tfName" prefWidth="240.0"/>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.agent.description" labelMinWidth="180" labelPrefWidth="180">
            <TextField fx:id="tfDescription" prefWidth="240.0"/>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.agent.chat.model" labelMinWidth="180" labelPrefWidth="180">
            <MChoiceBox fx:id="cbChatProvider" prefWidth="140.0">
            </MChoiceBox>
            <MChoiceBox fx:id="cbChatModel" prefWidth="180.0">
            </MChoiceBox>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.agent.prompt" labelMinWidth="180" labelPrefWidth="180">
            <TextArea fx:id="taAgentPrompt" prefWidth="280.0" prefRowCount="10" prefColumnCount="100" wrapText="true"
                      promptText="%prefs.ai.agent.prompt.placeholder">
            </TextArea>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.agent.language" labelMinWidth="180" labelPrefWidth="180">
            <MChoiceBox fx:id="cbLanguage" prefWidth="240.0"/>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.agent.embedding.model" labelMinWidth="180" labelPrefWidth="180">
            <MChoiceBox fx:id="cbEmbeddingProvider" prefWidth="140.0">
            </MChoiceBox>
            <MChoiceBox fx:id="cbEmbeddingModel" prefWidth="220.0">
            </MChoiceBox>
        </PreferenceItem>
        <PreferenceItem name="%prefs.ai.agent.datasets" labelMinWidth="180" labelPrefWidth="180">
            <DatasetTableView fx:id="tvDatasets" minHeight="80.0" minWidth="220.0" prefHeight="150.0" prefWidth="350.0">
            </DatasetTableView>
            <Button fx:id="btnSetDataset"/>
        </PreferenceItem>
    </VBox>

</fx:root>
